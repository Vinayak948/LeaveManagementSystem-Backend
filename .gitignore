## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
## Based on GitHub VisualStudio.gitignore

# =========================
# User-specific files
# =========================
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs
mono_crash.*

# =========================
# Build results
# =========================
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/
artifacts/

# =========================
# Visual Studio cache/options
# =========================
.vs/
Generated\ Files/

# =========================
# Test Results
# =========================
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml
nunit-*.xml

# =========================
# Files built by Visual Studio
# =========================
*_i.c
*_p.c
*_h.h
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.pdb
*.ipdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*_wpftmp.csproj
*.log
*.vspscc
*.vssscc
.builds
*.pidb
*.svclog
*.scc

# =========================
# C++ cache files
# =========================
ipch/
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb

# =========================
# Profiling & Coverage
# =========================
*.psess
*.vsp
*.vspx
*.sap
*.coverage
*.coveragexml
coverage*.json
coverage*.xml
coverage*.info
*.dotCover
.axoCover/*
!.axoCover/settings.json

# =========================
# ReSharper / Code tools
# =========================
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user
_TeamCity*
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*
.cr/personal
.ntvs_analysis.dat

# =========================
# Package Managers
# =========================
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
node_modules/
.paket/paket.exe
paket-files/

# =========================
# Publish / Deployment
# =========================
publish/
*.[Pp]ublish.xml
*.azurePubxml
*.pubxml
*.publishproj
PublishScripts/

# =========================
# Azure
# =========================
csx/
*.build.csdef
ecf/
rcf/
ASALocalRun/

# =========================
# Windows Store
# =========================
AppPackages/
BundleArtifacts/
Package.StoreAssociation.xml
_pkginfo.txt
*.appx
*.appxbundle
*.appxupload

# =========================
# SQL Server
# =========================
*.mdf
*.ldf
*.ndf

# =========================
# Misc
# =========================
ClientBin/
~$*
*~
*.dbmdl
*.dbproj.schemaview
*.jfm
*.pfx
*.publishsettings
orleans.codegen.cs
Generated_Code/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm
*.rptproj.bak
FakesAssemblies/
*.GhostDoc.xml
.healthchecksdb
MigrationBackup/
.localhistory/
.ionide/
.mfractor/
FodyWeavers.xsd
*.binlog
*.nvuser
__pycache__/
*.pyc

# =========================
# Application Configuration (ADDED)
# =========================
# Main config files (often contain secrets)
appsettings.json
appsettings.*.json

# Keep development config if desired
!appsettings.Development.json

# Environment variable files
.env
.env.*